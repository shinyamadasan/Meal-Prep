# CODEOWNERS — Example template
# Location: .github/CODEOWNERS
# Last matching rule wins (bottom of file takes precedence).
# See: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Default owner for everything not explicitly listed below
*                           @org/engineering-leads

# Source code — team ownership by domain
src/auth/                   @org/auth-team
src/payments/               @org/payments-team
src/api/                    @org/backend-team
src/components/             @org/frontend-team
src/app/                    @org/frontend-team

# Packages (monorepo pattern)
packages/auth/              @org/auth-team
packages/ui/                @org/design-system-team
packages/shared/            @org/platform-team

# Infrastructure and CI — platform team + at least one lead
.github/workflows/          @org/devops-team @org/platform-team
.github/CODEOWNERS          @org/platform-team @org/engineering-leads
terraform/                  @org/platform-team
infra/                      @org/platform-team
docker-compose*.yml         @org/devops-team

# Configuration — restricted
config/                     @org/platform-team
.env.example                @org/platform-team
secrets/                    @org/platform-team @org/security-leads

# Documentation — open ownership with docs team as backup
docs/                       @org/docs-team @org/engineering-leads
*.md                        @org/docs-team

# Database migrations — platform + relevant domain team
prisma/migrations/          @org/platform-team @org/backend-team
db/migrations/              @org/platform-team @org/backend-team
