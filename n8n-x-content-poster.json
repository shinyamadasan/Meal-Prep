      "typeVersion": 2.2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.url }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            },
            {
              "name": "User-Agent",
              "value": "n8n-meal-prep-poster"
            }
          ]
        },
        "options": {},
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "id": "github-get-content",
      "name": "GitHub: get file content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "name": "GitHub PAT - Meal Prep"
        }
      },
      "retryOnFail": true,
      "maxTries": 5,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "// Run Once for All Items. Each input item is one GitHub \"get contents\" response:\n// { name, path, sha, content: \"<base64>\", ... }. Decode, parse frontmatter, keep only\n// status: approved, sort by id (content-001 < content-002 sorts correctly as plain strings),\n// pick the oldest, split its body into individual tweets on a --- delimiter.\nfunction parseFrontmatter(raw) {\n  const m = raw.match(/^---\\r?\\n([\\s\\S]*?)\\r?\\n---\\r?\\n([\\s\\S]*)$/);\n  if (!m) return null;\n  const fm = {};\n  m[1].split(/\\r?\\n/).forEach((line) => {\n    const mm = line.match(/^([a-zA-Z_]+):\\s*(.*)$/);\n    if (mm) fm[mm[1]] = mm[2].trim();\n  });\n  return { fm, body: m[2] };\n}\n\nconst candidates = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  if (!j.content) continue;\n  const raw = Buffer.from(j.content, 'base64').toString('utf8');\n  const parsed = parseFrontmatter(raw);\n  if (!parsed) continue;\n  if ((parsed.fm.status || '').toLowerCase() !== 'approved') continue;\n  candidates.push({ path: j.path, sha: j.sha, id: parsed.fm.id || j.name.replace(/\\.md$/, ''), source: parsed.fm.source || '', body: parsed.body });\n}\n\nif (candidates.length === 0) return [{ json: { found: false, reason: 'no approved drafts in queue' } }];\n\ncandidates.sort((a, b) => (a.id > b.id ? 1 : -1));\nconst next = candidates[0];\nconst tweets = next.body.trim().split(/\\r?\\n---\\r?\\n/).map((t) => t.trim()).filter(Boolean);\nif (tweets.length === 0) throw new Error('content-poster: ' + next.id + ' has status: approved but no tweet text found in its body');\nif (tweets.length > 12) throw new Error('content-poster: ' + next.id + ' has ' + tweets.length + ' tweets, more than this workflow\\'s 12-tweet cap -- ask Claude to raise MAX_TWEETS and regenerate the posting chain');\n\nreturn [{ json: { found: true, path: next.path, sha: next.sha, id: next.id, source: next.source, tweets } }];"
      },
      "id": "pick-oldest",
      "name": "Pick oldest approved",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ]
    },
