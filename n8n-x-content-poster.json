    {
      "parameters": {
        "jsCode": "// Walks the fixed-size posting chain's node history to find how many tweets actually posted --\n// works whether the thread used all 12 slots or stopped early. Reached either from the\n// last slot's success or from any earlier slot's \"doesn't exist\" branch (a thread shorter than\n// 12 tweets), so this is the single place both paths converge.\nconst ids = [];\nconst orig = $('Pick oldest approved').item.json;\nfunction finish() {\n  return [{ json: { path: orig.path, sha: orig.sha, id: orig.id, source: orig.source, body: orig.tweets.join('\\n\\n---\\n\\n'), postedIds: ids, firstUrl: 'https://x.com/ShinYamadaSan/status/' + ids[0] } }];\n}\n  try { const d = $node[\"Post tweet 0\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 1\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 2\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 3\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 4\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 5\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 6\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 7\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 8\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 9\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 10\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\n  try { const d = $node[\"Post tweet 11\"].json; if (d && d.data && d.data.id) { ids.push(d.data.id); } else { throw 0; } } catch (e) { return finish(); }\nreturn finish();"
